<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="https://use.typekit.net/mhd1hjd.css">

    <style>
        /* ===== PAGE ===== */
        @page {
            size: A4;
            margin-left: 0.4cm;
            margin-right: 0.4cm;
            margin-top: 0.8cm;
            margin-bottom: 2cm;
        }

        html,
        body,
        * {
            font-family: "Trajan Pro" !important;
        }

        b,
        strong {
            font-family: "Trajan Pro" !important;
            font-weight: bold;
        }

        body {
            margin: 0;
            padding: 0;
            font-size: 10pt;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            color: #000;
        }

        /* ===== MAIN CONTENT WRAPPER ===== */
        .content-wrapper {
            /* Header yüksekliği + güvenlik boşluğu */
            padding-top: 5.5cm;
            min-height: 100vh;
        }

        /* ===== HEADER (fixed) ===== */
        .header-fixed {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 5cm;
            background-color: white;
            z-index: 1000;
            padding: 0.5cm 0.4cm;
            text-align: center;
            box-sizing: border-box;
        }

        .snocLogo {
            width: 250px;
            height: 80px;
            object-fit: contain;
            display: block;
            margin: 0 auto 10px auto;
        }

        .header-text {
            font-size: 7pt;
            font-weight: normal;
            color: #333;
            line-height: 1.3;
        }

        /* ===== TITLE ===== */
        .main-title-wrap {
            text-align: center;
            width: 100%;
            margin-top: 0;
            margin-bottom: 12px;
        }

        .main-title {
            font-size: 13.77pt !important;
            font-weight: bold !important;
            border-bottom: 1px solid #000;
            display: inline-block;
            padding-bottom: 2px;
            letter-spacing: 0.5px;
        }

        /* ===== TOP INFO ===== */
        .top-info {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
        }

        .top-info td {
            font-size: 8pt;
            vertical-align: top;
            padding: 3px 0;
        }

        .top-left {
            width: 50%;
            text-align: left;
        }

        .top-right {
            width: 50%;
            text-align: right;
        }

        /* ===== LINES TABLE ===== */
        table.quote-lines-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 12px;
            font-size: 7pt;
            table-layout: fixed;
        }

        table.quote-lines-table thead th {
            font-size: 8.61pt !important;
            font-weight: bold !important;
            background: #bfbfbf;
            color: #000;
            text-align: center;
            padding: 6px 4px;
            border: 1px solid #fff;
            letter-spacing: 0.4px;
            vertical-align: middle;
            overflow: hidden;
            text-overflow: clip;
            white-space: nowrap;
        }

        table.quote-lines-table tbody td {
            font-size: 7.79pt !important;
            font-weight: normal !important;
            text-align: center;
            padding: 6px 4px;
            vertical-align: middle;
            border: 1px solid #fff;
        }

        tr.data-row {
            page-break-inside: avoid;
            break-inside: avoid;
        }

        td.imgCell {
            width: 16%;
        }

        td.imgCell img {
            width: 120px;
            height: 80px;
            object-fit: contain;
            display: block;
            margin: 0 auto;
        }

        td.descCell {
            width: 32%;
            text-align: left;
            word-break: break-word;
            overflow-wrap: anywhere;
        }

        .prod-name {
            display: block;
            font-size: 7.2pt !important;
            font-weight: normal !important;
            margin-bottom: 2px;
        }

        .prod-link,
        .prod-desc,
        .prod-dim {
            font-size: 5.5pt !important;
            font-weight: normal !important;
            margin-top: 2px;
        }

        .prod-link {
            display: block;
            font-style: normal;
            word-break: break-word;
        }

        .prod-desc {
            display: block;
        }

        .prod-dim {
            display: block;
        }

        .cur {
            margin-left: 6px;
            font-size: 8pt;
            white-space: nowrap;
        }

        .th-discount,
        .th-stock {
            white-space: normal !important;
            line-height: 1.05;
        }

        /* ===== TOTALS ===== */
        .totals-wrap {
            page-break-inside: avoid;
            break-inside: avoid;
            margin-top: 15px;
        }

        .line-hr {
            border-top: 0.5px solid #000;
            width: 100%;
            margin: 10px 0;
        }

        .totals-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 8.61pt !important;
        }

        .totals-label {
            font-size: 8.61pt !important;
            font-weight: normal !important;
            text-align: left;
            white-space: nowrap;
        }

        .totals-value {
            font-size: 8.61pt !important;
            font-weight: normal !important;
            text-align: right;
            white-space: nowrap;
        }

        /* ===== NOTES ===== */
        .notes {
            margin-top: 12px;
            font-size: 5.3pt !important;
            font-weight: normal !important;
            line-height: 1.4;
        }

        .notes .note {
            margin: 3px 0;
        }

        /* ===== PAGE BREAKS ===== */
        .page-break {
            page-break-after: always;
            break-after: page;
        }

        /* ===== BANK PAGE ===== */
        .bank-page {
            page-break-before: always;
            break-before: page;
        }

        .bank-content {
            padding-top: 5.5cm;
        }

        .bank-title-wrap {
            text-align: center;
            width: 100%;
            margin-top: 30px;
            margin-bottom: 30px;
        }

        .bank-title {
            font-size: 12pt;
            font-weight: bold;
            border-bottom: 1px solid #000;
            display: inline-block;
            padding-bottom: 2px;
            letter-spacing: 0.6px;
        }

        .bank-block {
            width: 70%;
            margin: 0 auto 22px auto;
            border-collapse: collapse;
            font-size: 9pt;
        }

        .bank-block td {
            padding: 5px 8px;
            vertical-align: top;
        }

        .bank-label {
            font-size: 12pt !important;
            white-space: nowrap;
            font-weight: normal !important;
        }

        .bank-value {
            font-size: 12pt !important;
            width: auto;
            font-weight: normal !important;
        }

        .lbl-779 {
            font-size: 7.79pt !important;
            font-weight: bold !important;
        }

        .val-861 {
            font-size: 8.61pt !important;
            font-weight: normal !important;
        }

        .val-861b {
            font-size: 8.61pt !important;
            font-weight: bold !important;
        }

        .email-no-link,
        .email-no-link * {
            text-decoration: none !important;
            color: #000 !important;
        }

        a {
            text-decoration: none !important;
            color: #000 !important;
        }

        /* DEBUG - Uncomment to see boundaries */
        /*
        .header-fixed {
            border: 3px solid red;
        }
        .content-wrapper {
            border: 3px solid blue;
        }
        */
    </style>
</head>

