<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />

    <style>
        /* ===== TRAJAN PRO - BASE64 GÖMÜLÜ FONT ===== */
        @font-face {
            font-family: "Trajan Pro";
            src: url('data:font/opentype;base64,{{{fontRegularB64}}}') format('opentype');
            font-weight: normal;
            font-style: normal; 
            font-display: block;
        }

        @font-face {
            font-family: "Trajan Pro";
            src: url('data:font/opentype;base64,{{{fontBoldB64}}}') format('opentype');
            font-weight: bold;
            font-style: normal;
            font-display: block;
        }

        /* ===== FONT ENFORCEMENT ===== */
        html,
        body,
        *,
        *::before,
        *::after {
            font-family: "Trajan Pro", serif !important;
        }

        b,
        strong {
            font-family: "Trajan Pro", serif !important;
            font-weight: bold !important;
        }

        /* ===== PAGE ===== */
        @page {
            size: A4;
            margin-left: 0.4cm;
            margin-right: 0.4cm;
            margin-top: 0.2cm;
            margin-bottom: 2cm;
        }

        body {
            margin: 0;
            padding: 0;
            font-size: 10pt;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            color: #000;
        }

        /* ===== PAGE CONTAINER ===== */
        .page-container {
            page-break-after: always;
            break-after: page;
        }

        .page-container:last-of-type {
            page-break-after: auto;
        }

        /* ===== HEADER ===== */
        .page-header {
            width: 100%;
            text-align: center;
            padding: 15px 0 15px 0;
            margin-bottom: 15px;
        }

        .snocLogo {
            width: 187px;
            height: 80px;
            object-fit: contain;
            display: block;
            margin: 0 auto;
        }

        .header-text {
            font-family: "Trajan Pro", serif !important;
            font-size: 5pt;
            font-weight: normal;
            color: #333;
            margin-top: 6px;
            line-height: 1.5;
        }

        /* ===== TITLE ===== */
        .main-title-wrap {
            text-align: center;
            width: 100%;
            margin-top: 0;
            margin-bottom: 8px;
        }

        .main-title {
            font-family: "Trajan Pro", serif !important;
            font-size: 10pt !important;
            font-weight: bold !important;
            border-bottom: 1px solid #000;
            display: inline-block;
            padding-bottom: 2px;
            letter-spacing: 0.5px;
        }

        /* ===== TOP INFO ===== */
        .top-info {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 6px;
        }

        .top-info td {
            font-family: "Trajan Pro", serif !important;
            font-size: 8pt;
            vertical-align: top;
            padding: 2px 0;
        }

        .top-left {
            width: 50%; 
            text-align: left; 
            vertical-align: top;
            font-size: 6pt !important; 
        }

        .sayin-label {
            font-weight: bold !important;
            margin-right: 4px;  
        }

        .top-right {
            width: 50%;
            text-align: left;
            padding-top: 2px;
        }

        .top-right div {
            font-size: 6pt !important;
            margin-bottom: 8px; 
        }

        .info-container {
            display: inline-block;
            text-align: left; 
            min-width: 180px; 
            padding-left: 150px;
            font-size: 10pt !important;
        }

        .info-row {
            font-size: 8pt !important; 
            margin-bottom: 8px; 
        }

        .info-label {
            display: inline-block;
            width: 60px;
            text-align: left;
            font-weight: bold !important;
        }

        /* ===== LINES TABLE ===== */
        table.quote-lines-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
            font-size: 7pt;
            table-layout: fixed;
        }

        table.quote-lines-table thead th {
            font-family: "Trajan Pro", serif !important;
            font-size: 6.45pt !important;
            font-weight: bold !important;
            background: #bfbfbf;
            color: #000;
            text-align: center;
            padding: 4px 4px;
            border: 1px solid #fff;
            letter-spacing: 0.4px;
            vertical-align: middle;
            overflow: hidden;
            text-overflow: clip;
            white-space: nowrap;
        }

        table.quote-lines-table tbody td {
            font-family: "Trajan Pro", serif !important;
            font-size: 6.2pt !important;
            font-weight: normal !important;
            text-align: center;
            padding: 10px 4px;
            vertical-align: middle;
            border: 1px solid #fff;
        }

        tr.data-row {
            page-break-inside: avoid;
            break-inside: avoid;
        }

        tr.link-row {
            page-break-inside: avoid;
            break-inside: avoid;
        }

        td.imgCell {
            width: 16%;
        }

        td.imgCell img {
            width: 120px;
            height: 80px;
            object-fit: contain;
            display: block;
            margin: 0 auto;
        }

        td.descCell {
            width: 32%;
            text-align: left;
            word-break: break-word;
            overflow-wrap: anywhere;
        }

        .text-right {
            text-align: right !important;
            padding-right: 8px !important;
        }

        .prod-name {
            font-family: "Trajan Pro", serif !important;
            display: block;
            font-size: 5.7pt !important;
            font-weight: normal !important;
            margin-bottom: 8px;
        }

        .prod-desc,
        .prod-dim {
            font-family: "Trajan Pro", serif !important;
            font-size: 6.3pt !important;
            font-weight: normal !important;
            margin-top: 2px;
        }

        .prod-desc {
            display: block;
        }

        .prod-dim {
            display: block;
        }

        .prod-link-row {
            font-family: "Trajan Pro", serif !important; 
            font-size: 5.5pt !important;
            text-align: left;
            text-decoration: none !important;
            color: #000 !important;
            display: block;
            margin-top: 4px;
        }

        .cur {
            font-family: "Calibri", serif !important;
            margin-left: 6px;
            font-size: 6pt !important;
            white-space: nowrap;
        }

        .th-discount,
        .th-stock {
            white-space: normal !important;
            line-height: 1.05;
        }

        /* ===== TOTALS ===== */
        .totals-wrap {
            page-break-inside: avoid;
            break-inside: avoid;
            margin-top: 15px;
        }

        .line-hr {
            border-top: 0.1px solid #888; 
            height: 0px;
            width: 100%;
            margin: 5px 0;
        }

        .totals-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 6pt !important;
            padding: 4px 0;
        }

        .totals-label {
            font-family: "Trajan Pro", serif !important;
            font-size: 7pt !important;
            font-weight: normal !important;
            text-align: left;
            white-space: nowrap;
            line-height: 2;
        }

        .totals-value {
            font-family: "Trajan Pro", serif !important;
            font-size: 7pt !important;
            font-weight: normal !important;
            text-align: right;
            white-space: nowrap;
        }

        /* ===== NOTES ===== */
        .notes {
            margin-top: 15px;
            font-size: 5pt !important;
            font-weight: normal !important;
            line-height: 2.5;
        }

        .notes .note {
            font-family: "Trajan Pro", serif !important;
            margin: 3px 0;
        }

        /* ===== BANK PAGE ===== */
        .bank-title-wrap {
            text-align: center;
            width: 100%;
            margin-top: 25px;
            margin-bottom: 50px;
        }

        .bank-title {
            font-family: "Trajan Pro", serif !important;
            font-size: 7.8pt;
            font-weight: bold;
            border-bottom: 1px solid #000;
            display: inline-block;
            padding-bottom: 2px;
            letter-spacing: 0.6px;
        }

        .bank-block {
            width: 70%;
            margin: 0 auto 22px auto;
            border-collapse: collapse;
            font-size: 9pt;
        }

        .bank-block td {
            font-family: "Trajan Pro", serif !important;
            font-size: 6.5pt !important;
            padding: 4px 6px;
            vertical-align: top;
        }

        .bank-label {
            font-family: "Trajan Pro", serif !important;
            font-size: 12pt !important;
            white-space: nowrap;
            font-weight: normal !important;
        }

        .bank-value {
            font-family: "Trajan Pro", serif !important;
            font-size: 12pt !important;
            width: auto;
            font-weight: normal !important;
        }

        .lbl-779 {
            font-family: "Trajan Pro", serif !important;
            font-size: 7.79pt !important;
            font-weight: bold !important;
        }

        .val-861 {
            font-family: "Trajan Pro", serif !important;
            font-size: 8.61pt !important;
            font-weight: normal !important;
        }

        .val-861b {
            font-family: "Trajan Pro", serif !important;
            font-size: 8.61pt !important;
            font-weight: bold !important;
        }

        .email-no-link,
        .email-no-link * {
            text-decoration: none !important;
            color: #000 !important;
        }

        a {
            text-decoration: none !important;
            color: #000 !important;
        }
    </style>
</head>

<body>

    <!-- LINE PAGES -->
    {{#if pages}}
    {{#each pages}}

    <div class="page-container">
        <!-- HEADER (her sayfada tekrar) -->
        <div class="page-header">
            {{#if ../logoDataUri}}
            <img class="snocLogo" src="{{{../logoDataUri}}}" alt="Logo" />
            {{/if}}
            <div class="header-text">
                EKVATOR ISI MÜHENDİSLİK İNŞ. SAN. VE TİC. LTD. ŞTİ.<br />
                NECİP FAZIL BULVARI NO:46/A Y.DUDULLU / ÜMRANİYE / İSTANBUL/TÜRKİYE<br />
                TEL: +90 (850) 800 64 64
            </div>
        </div>

        <!-- TITLE ve TOP INFO (sadece ilk sayfada) -->
        {{#if @first}}
        <div class="main-title-wrap">
            <span class="main-title">TEKLİF FORMU</span>
        </div>

        <table class="top-info">
            <tr>
                <td class="top-left">
                    <span class="sayin-label">SAYIN:</span>
                    <span>{{../sayin}}</span>
                </td>
                <td class="top-right">
                    <div class="info-container">
                        <div class="info-row"><b>{{../today}}</b></div>
                        <div class="info-row"><span class="info-label">İLETİŞİM:</span> <span>{{../ownerName}}</span></div>
                        <div class="info-row"><span class="info-label">E-MAIL:</span> <span>{{../ownerEmail}}</span></div>
                    </div>
                </td>
            </tr>
        </table>
        {{/if}}

        <table class="quote-lines-table">
            <thead>
                <tr>
                    <th style="width:16%;">FOTOĞRAF</th>
                    <th style="width:28%;">AÇIKLAMA</th>
                    <th style="width:6%;">ADET</th>
                    <th style="width:11%;">BİRİM FİYATI</th>
                    <th style="width:8%;">TOPLAM</th>
                    <th class="th-discount" style="width:10%;">İNDİRİMLİ<br />TUTAR</th>
                    <th class="th-stock" style="width:10%;">STOK<br />DURUMU</th>
                </tr>
            </thead>

            <tbody>
                {{#each lines}}
                <tr class="data-row">
                    <td class="imgCell">
                        {{#if hasImage}}
                        <img src="{{{imageDataUri}}}" alt="Product" />
                        {{/if}}
                    </td>

                    <td class="descCell">
                        {{#if productName}}
                        <span class="prod-name">{{productName}}</span>
                        {{/if}}

                        {{#if description}}
                        <span class="prod-desc">{{description}}</span>
                        {{/if}}

                        {{#if dimension}}
                        <span class="prod-dim">{{dimension}}</span>
                        {{/if}}
                    </td>

                    <td>{{quantity}}</td>
                    <td>{{unitPrice}} <span class="cur">₺</span></td>
                    <td>{{subTotal}} <span class="cur">₺</span></td>
                    <td>{{totalPrice}} <span class="cur">₺</span></td>
                    <td>{{stockStatus}}</td>
                </tr>
                {{#if productLink}}
                <tr class="link-row">
                    <td colspan="7" style="text-align:center; padding: 0 4px 8px 4px; border: 1px solid #fff;">
                        <a class="prod-link-row" href="{{productLink}}" target="_blank">{{productLink}}</a>
                    </td>
                </tr>
                {{/if}}
                {{/each}}
            </tbody>
        </table>

        {{#if @last}}
        <!-- TOTALS (sadece en son sayfada) -->
        <div class="totals-wrap">
            <div class="line-hr"></div>

            <table class="totals-table">
                <tr>
                    <td style="width:70%;">&nbsp;</td>
                    <td class="totals-label" style="width:15%;">TOPLAM</td>
                    <td class="totals-value" style="width:15%;">{{../totalAmount}} ₺</td>
                </tr>
                <tr>
                    <td>&nbsp;</td>
                    <td class="totals-label">TOPLAM İNDİRİM</td>
                    <td class="totals-value">{{../totalDiscount}} ₺</td>
                </tr>
                <tr>
                    <td>&nbsp;</td>
                    <td class="totals-label">GENEL TOPLAM</td>
                    <td class="totals-value">{{../grandTotal}} ₺</td>
                </tr>
            </table>

            <div class="line-hr"></div>
        </div>

        <!-- NOTES -->
        <div class="notes">
            <div class="note">- TEKLİFTE KULLANILAN GÖRSELLER TANITIM AMAÇLI OLUP AÇIKLAMALAR DİKKATE ALINMALIDIR.</div>
            <div class="note">- {{../notePayment}}</div>
            <div class="note">- {{../noteDelivery}}</div>
            <div class="note">- {{../noteKdv}}</div>
            <div class="note">- {{../noteValidity}}</div>
        </div>
        {{/if}}

    </div>

    {{/each}}

    {{else}}
    <!-- fallback -->
    <div class="page-container">
        <div class="page-header">
            {{#if logoDataUri}}
            <img class="snocLogo" src="{{{logoDataUri}}}" alt="Logo" />
            {{/if}}
            <div class="header-text">
                EKVATOR ISI MÜHENDİSLİK İNŞ. SAN. VE TİC. LTD. ŞTİ.<br />
                NECİP FAZIL BULVARI NO:46/A Y.DUDULLU / ÜMRANİYE / İSTANBUL/TÜRKİYE<br />
                TEL: +90 (850) 800 64 64
            </div>
        </div>

        <div class="main-title-wrap">
            <span class="main-title">TEKLİF FORMU</span>
        </div>

        <table class="top-info">
            <tr>
                <td class="top-left">
                    <span class="lbl-779">SAYIN:</span>
                    <span class="val-861">{{sayin}}</span>
                </td>
                <td class="top-right">
                    <div><span class="val-861b">{{today}}</span></div>
                    <div><span class="lbl-779">İLETİŞİM:</span> <span class="val-861">{{ownerName}}</span></div>
                    <div><span class="lbl-779">E-MAIL:</span> <span class="val-861 email-no-link">{{ownerEmail}}</span></div>
                </td>
            </tr>
        </table>

        <table class="quote-lines-table">
            <thead>
                <tr>
                    <th style="width:16%;">FOTOĞRAF</th>
                    <th style="width:20%;">AÇIKLAMA</th>
                    <th style="width:6%;">ADET</th>
                    <th style="width:13%;">BİRİM FİYATI</th>
                    <th style="width:8%;">TOPLAM</th>
                    <th class="th-discount" style="width:10%;">İNDİRİMLİ<br />TUTAR</th>
                    <th class="th-stock" style="width:10%;">STOK<br />DURUMU</th>
                </tr>
            </thead>
            <tbody>
                {{#each lines}}
                <tr class="data-row">
                    <td class="imgCell">
                        {{#if hasImage}}
                        <img src="{{{imageDataUri}}}" alt="Product" />
                        {{/if}}
                    </td>
                    <td class="descCell">
                        {{#if productName}}<span class="prod-name">{{productName}}</span>{{/if}}
                        {{#if description}}<span class="prod-desc">{{description}}</span>{{/if}}
                        {{#if dimension}}<span class="prod-dim">{{dimension}}</span>{{/if}}
                    </td>
                    <td>{{quantity}}</td>
                    <td>{{unitPrice}} <span class="cur">₺</span></td>
                    <td>{{subTotal}} <span class="cur">₺</span></td>
                    <td>{{totalPrice}} <span class="cur">₺</span></td>
                    <td>{{stockStatus}}</td>
                </tr>
                {{#if productLink}}
                <tr class="link-row">
                    <td colspan="7" style="text-align:center; padding: 0 4px 8px 4px; border: 1px solid #fff;">
                        <a class="prod-link-row" href="{{productLink}}" target="_blank">{{productLink}}</a>
                    </td>
                </tr>
                {{/if}}
                {{/each}}
            </tbody>
        </table>
    </div>
    {{/if}}

    <!-- BANK PAGE -->
    <div class="page-container">
        <div class="page-header">
            {{#if logoDataUri}}
            <img class="snocLogo" src="{{{logoDataUri}}}" alt="Logo" />
            {{/if}}
            <div class="header-text">
                EKVATOR ISI MÜHENDİSLİK İNŞ. SAN. VE TİC. LTD. ŞTİ.<br />
                NECİP FAZIL BULVARI NO:46/A Y.DUDULLU / ÜMRANİYE / İSTANBUL/TÜRKİYE<br />
                TEL: +90 (850) 800 64 64
            </div>
        </div>

        <div class="bank-title-wrap">
            <div class="bank-title">HESAP BİLGİLERİMİZ</div>
        </div>

        <table class="bank-block">
            <tr>
                <td class="bank-label">BANKA ADI</td>
                <td class="bank-value">GARANTİ BANKASI</td>
            </tr>
            <tr>
                <td class="bank-label">HESAP BİLGİSİ</td>
                <td class="bank-value">EKVATOR ISI MÜHENDİSLİK İNŞ. SAN. VE TİC. LTD.ŞTİ</td>
            </tr>
            <tr>
                <td class="bank-label">HESAP NUMARASI</td>
